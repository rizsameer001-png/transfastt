PORT=5000
MONGO_URI=mongodb://localhost:27017/transfast
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Email Config (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@transfast.com

# FX Rate API (Free: exchangerate.host or openexchangerates.org)
FX_API_KEY=your_fx_api_key
FX_API_URL=https://api.exchangerate.host/latest

# Frontend URL
CLIENT_URL=http://localhost:5173

# Cloudinary (Free tier: 25GB storage + 25GB bandwidth/month)
# Sign up at https://cloudinary.com → Dashboard → copy these 3 values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin defaults
ADMIN_EMAIL=admin@transfast.com
ADMIN_PASSWORD=Admin@123456
